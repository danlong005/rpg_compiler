**FREE
// Test 105: RLA — WRITE, UPDATE, DELETE

DCL-F CUSTFL105 DISK KEYED EXTDESC('custfl105');

DCL-S connStr VARCHAR(200);
DCL-S key     VARCHAR(10);

connStr = 'Driver={SQLite3};Database=/tmp/rpgc_test105.sqlite;';
EXEC SQL CONNECT USING :connStr;

EXEC SQL CREATE TABLE custfl105 (
  CUSTNO VARCHAR(10) PRIMARY KEY,
  CUSTNAME VARCHAR(50),
  CUSTBAL DECIMAL(9,2)
);

// WRITE a new record
CUSTNO   = 'W001';
CUSTNAME = 'WriteTest';
CUSTBAL  = 500.00;
WRITE CUSTFL105;

// Verify via CHAIN
key = 'W001';
CHAIN key CUSTFL105;
IF %FOUND(CUSTFL105);
  DSPLY CUSTNAME;
ENDIF;

// UPDATE the record
CUSTNAME = 'Updated';
CUSTBAL  = 999.99;
UPDATE CUSTFL105;

// Verify update via CHAIN
CHAIN key CUSTFL105;
IF %FOUND(CUSTFL105);
  DSPLY CUSTNAME;
ENDIF;

// DELETE the record
DELETE CUSTFL105;

// Verify deletion via CHAIN
CHAIN key CUSTFL105;
IF NOT %FOUND(CUSTFL105);
  DSPLY 'deleted';
ENDIF;

EXEC SQL DROP TABLE custfl105;
EXEC SQL DISCONNECT;

*INLR = *ON;

**FREE

// Test 108: RLA via rpgc.conf — no explicit EXEC SQL CONNECT or DISCONNECT

DCL-F CUSTFL108 DISK KEYED EXTDESC('custfl108');

DCL-S key VARCHAR(10);

EXEC SQL CREATE TABLE custfl108 (
  CUSTNO   VARCHAR(10) PRIMARY KEY,
  CUSTNAME VARCHAR(50)
);
EXEC SQL INSERT INTO custfl108 VALUES('A001','Alpha');
EXEC SQL INSERT INTO custfl108 VALUES('B002','Beta');
EXEC SQL INSERT INTO custfl108 VALUES('C003','Gamma');

key = 'B002';
CHAIN key CUSTFL108;
IF %FOUND(CUSTFL108);
  DSPLY CUSTNO;
  DSPLY CUSTNAME;
ENDIF;

key = 'Z999';
CHAIN key CUSTFL108;
IF NOT %FOUND(CUSTFL108);
  DSPLY 'not found';
ENDIF;

EXEC SQL DROP TABLE custfl108;

*INLR = *ON;

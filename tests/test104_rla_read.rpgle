**FREE
// Test 104: RLA — READ sequential loop, %EOF

DCL-F CUSTFL104 DISK EXTDESC('custfl104');

DCL-S connStr VARCHAR(200);

connStr = 'Driver={SQLite3};Database=/tmp/rpgc_test104.sqlite;';
EXEC SQL CONNECT USING :connStr;

EXEC SQL CREATE TABLE custfl104 (
  CUSTNO VARCHAR(10),
  CUSTNAME VARCHAR(50),
  CUSTBAL DECIMAL(9,2)
);

EXEC SQL INSERT INTO custfl104 VALUES('A001','Alice',100.00);
EXEC SQL INSERT INTO custfl104 VALUES('A002','Bob',200.00);
EXEC SQL INSERT INTO custfl104 VALUES('A003','Carol',300.00);

// Sequential read loop
READ CUSTFL104;
DOW NOT %EOF(CUSTFL104);
  DSPLY CUSTNAME;
  READ CUSTFL104;
ENDDO;

EXEC SQL DROP TABLE custfl104;
EXEC SQL DISCONNECT;

*INLR = *ON;
